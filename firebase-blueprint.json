{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "Patient medical record",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "patientId": { "type": "string" },
        "age": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "phoneNumber": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "email": { "type": "string" },
        "doctorName": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["fullName", "patientId", "email"]
    },
    "Report": {
      "title": "Report",
      "description": "Diagnostic report for a patient",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "testType": { "type": "string", "enum": ["acuity", "contrast", "field", "other"] },
        "examDate": { "type": "number" },
        "rightEyeFiles": { "type": "array" },
        "leftEyeFiles": { "type": "array" },
        "whatsappStatus": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "analysis": { "type": "object" }
      }
    }
  },
  "firestore": {
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Patient records"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Diagnostic reports"
    }
  }
}
